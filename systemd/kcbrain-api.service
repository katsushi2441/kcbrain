[Unit]
Description=Kurage Crypto Brain API
After=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/kojima/work/kcbrain
EnvironmentFile=/home/kojima/work/kcbrain/.env
ExecStart=/home/kojima/work/kcbrain/.venv/bin/uvicorn kcbrain.api:app --host 0.0.0.0 --port 18328
Restart=always
RestartSec=5

[Install]
WantedBy=default.target
